{
  "name": "some-bark-some-bite",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "build": "npm run build --workspaces",
    "start:server": "npm --workspace @sbsb/server run start",
    "start:client": "npm --workspace @sbsb/client run dev",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\""
  },
  "devDependencies": {
    "concurrently": "^8.0.1"
  }
}
